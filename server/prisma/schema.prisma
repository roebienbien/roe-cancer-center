generator client {
  provider = "prisma-client-js"
  // binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String
  role        Role      @default(PATIENT)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  deletedById String?

  patient Patient?
  doctor  Doctor?
}

model Patient {
  id     String @id @default(uuid())
  userId String @unique

  lastName   String?
  firstName  String?
  middleName String?
  birthDate  DateTime
  sex        String?

  phone   String?
  // make this full address later
  address String?

  //medical-related 
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]
}

model Doctor {
  id     String @id @default(uuid())
  userId String @unique

  firstName String
  LastName  String

  specialization String? //oncology, general, etc.
  licenseNumber  String? @unique

  phone String?
  email String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  appointments Appointment[]
}

model Appointment {
  id String @id @default(uuid())

  patient   Patient? @relation(fields: [patientId], references: [id])
  patientId String?

  doctor   Doctor? @relation(fields: [doctorId], references: [id])
  doctorId String?

  startAt DateTime
  endAt   DateTime
  status  AppointmentStatus @default(PENDING)

  //optional: link to doctor later
  //doctorId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // user   User?   @relation(fields: [userId], references: [id])
  // userId String?
}

model AuditLog {
  id       String  @id @default(uuid())
  action   String
  entity   String
  entityId String
  actorId  String?

  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}

enum AppointmentStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  PATIENT
}
